# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# All values optional until the milestone that needs them.

# Upstox API v2 (M17) — https://account.upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8700/auth/callback

# Stopgap for `pt data stream` (M10) ahead of M17's automatic daily re-auth
# flow: paste a manually-obtained Upstox access token here. Expires daily.
UPSTOX_ACCESS_TOKEN=

# Anthropic (M14)
ANTHROPIC_API_KEY=

# Amazon Bedrock (alternative LLM backend, M14) — long-term Bedrock API key + region
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=

# Fernet key encrypting the stored Upstox daily token (M17).
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PT_TOKEN_ENCRYPTION_KEY=

# Dashboard auth (M16) — argon2 hash + session-cookie signing key, both
# generated together by `pt auth set-password`
PT_DASHBOARD_PASSWORD_HASH=
PT_DASHBOARD_SESSION_SECRET=
